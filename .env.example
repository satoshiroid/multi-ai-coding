# =========================================================================
# Multi-AI Coding — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# =========================================================================

# --- LLM providers -------------------------------------------------------
# Anthropic API key (used for L1/L2 high-reasoning tiers).
# NOTE: A Claude Pro/Max *subscription* does NOT grant API access — you need
# a pay-as-you-go API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API key (free tier works for L3 implement/debug tiers).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Ollama local server (fully free / offline). Default endpoint shown.
OLLAMA_BASE_URL=http://localhost:11434

# --- Discord owner channel ----------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# The forum channel ID where each product project becomes its own thread.
DISCORD_FORUM_CHANNEL_ID=

# Your Discord user ID. Only this user may approve / reject HITL gates.
OWNER_USER_ID=

# --- Misc ----------------------------------------------------------------
# Path to the SQLite state store (pipeline persistence / restart safety).
STATE_DB_PATH=./data/state.db
