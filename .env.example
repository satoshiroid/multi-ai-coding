# =========================================================================
# Multi-AI Coding — environment variables
# Copy to `.env` and fill in. Never commit `.env`.
# =========================================================================

# --- LLM providers -------------------------------------------------------
# Anthropic API key (used for L1/L2 high-reasoning tiers).
# NOTE: A Claude Pro/Max *subscription* does NOT grant API access — you need
# a pay-as-you-go API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Google Gemini API key (free tier works for L3 implement/debug tiers).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI API key (for the "openai" provider). Get one at
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama local server (fully free / offline). Default endpoint shown.
OLLAMA_BASE_URL=http://localhost:11434

# --- LLM selection (override config/settings.yaml from env / Git) --------
# Pick provider+model per tier without editing settings.yaml. In GitHub these
# go in repository *Variables* (non-secret); keys above stay in *Secrets*.
# Providers: anthropic (Claude) | gemini | openai | ollama. Set provider+model
# together. Resolution precedence, high→low:
#   LLM_FORCE_*  >  LLM_AGENT_<NAME>_*  >  settings.yaml agents.<name>
#                >  LLM_L{n}_*  >  settings.yaml tiers.L{n}
#
# Force every agent onto one model (e.g. A/B test); the run `llm` dropdown sets this:
#   LLM_FORCE_PROVIDER=
#   LLM_FORCE_MODEL=
# Per-agent ("virtual employee") override — NAME ∈ PM/SENIOR/DESIGN/MECHA/CIRCUIT/SOFTWARE:
#   LLM_AGENT_DESIGN_PROVIDER=
#   LLM_AGENT_DESIGN_MODEL=
#   LLM_AGENT_DESIGN_FALLBACK_PROVIDER=   # optional
#   LLM_AGENT_DESIGN_FALLBACK_MODEL=
# Per-tier baseline override:
#   LLM_L1_PROVIDER=   # PM   (L1)
#   LLM_L1_MODEL=
#   LLM_L2_PROVIDER=   # senior (L2)
#   LLM_L2_MODEL=
#   LLM_L3_PROVIDER=   # workers (L3)
#   LLM_L3_MODEL=

# --- Discord owner channel ----------------------------------------------
# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# The forum channel ID where each product project becomes its own thread.
# (Used by the legacy in-process bot, examples/run_server.py.)
DISCORD_FORUM_CHANNEL_ID=

# Your Discord user ID. Only this user may approve / reject HITL gates.
OWNER_USER_ID=

# --- Intake → GitHub Actions dispatch (examples/run_dispatch_bot.py) -----
# The GitHub-centric flow. A new post in one of these two forum channels is
# routed to GitHub Actions with project_type decided by *which* channel it is
# (deterministic code lookup — no LLM classification).
HARDWARE_CHANNEL_ID=        # forum channel → project_type "hardware" (self-hosted macOS runner)
APP_CHANNEL_ID=             # forum channel → project_type "app"      (hosted ubuntu runner)

# Repo + token used to fire repository_dispatch (event_type: new-project).
# Token: a PAT with `repo` (write) scope. Keep it out of git — this .env copy is
# gitignored; CAD/LLM keys live in GitHub Secrets, not here.
GITHUB_REPO=                # e.g. satoshiroid/multi-ai-coding
GITHUB_DISPATCH_TOKEN=

# Optional: webhook URL the build workflow uses to post the PR link back into
# the originating Discord thread (set the same value as a GitHub Secret).
DISCORD_WEBHOOK_URL=

# --- Misc ----------------------------------------------------------------
# Path to the SQLite state store (pipeline persistence / restart safety).
STATE_DB_PATH=./data/state.db
